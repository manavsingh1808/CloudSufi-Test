# Copy this file to .env and fill in your real key. Do NOT commit .env.

# OpenRouter (LLM gateway) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides (defaults shown)

# Where ChromaDB persists vectors on disk (relative to project root)
CHROMA_DIR=./chroma_data
CHROMA_COLLECTION=doc-qa

# Local embeddings model (downloads ~80 MB on first run; no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Any model slug from https://openrouter.ai/models -- :free variants are free.
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free

# Optional, shown on OpenRouter analytics
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_SITE_TITLE=Doc Q&A RAG

CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
